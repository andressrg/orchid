# Copy this to .env and fill in values before running setup.sh or ralph.sh
# Never commit .env

# Required: Anthropic API key for Claude Code
ANTHROPIC_API_KEY=sk-ant-...

# Required: Git identity for Ralph's commits
GIT_USER_NAME=Ralph
GIT_USER_EMAIL=ralph@yourproject.com

# Required: GitHub token for pushing branches (fine-grained PAT)
# Permissions needed: Contents: write, Pull requests: write
GITHUB_TOKEN=ghp_...

# The GitHub repo in owner/repo format
GITHUB_REPO=juliankmazo/orchid-ralph-hackaton

# Optional: Stripe billing for the Orchid web app
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_TEAM_PRICE_ID=price_...
BETTER_AUTH_URL=http://localhost:3000
STRIPE_TEAM_ANNUAL_PRICE_ID=price_...
STRIPE_TEAM_LOOKUP_KEY=orchid_team_monthly
STRIPE_TEAM_ANNUAL_LOOKUP_KEY=orchid_team_annual
STRIPE_TEAM_SEAT_PRICE_ID=price_...
STRIPE_BILLING_ENFORCEMENT=false
