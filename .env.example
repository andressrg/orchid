# Copy this to .env and fill in values. Never commit .env (it's gitignored).
# These cover the web app (web/), the CLI (cli/), and the autonomous orchestrator.

# ── Database ───────────────────────────────────────────────────────────────
# Neon (prod) or local docker postgres (dev): postgresql://orchid:orchid@localhost:5432/orchid
DATABASE_URL=postgresql://...

# ── AI ─────────────────────────────────────────────────────────────────────
# Claude is the primary brain for summaries, review context, and Q&A.
ANTHROPIC_API_KEY=sk-ant-...
# Optional legacy fallback; being phased out in favor of Claude.
OPENAI_API_KEY=

# ── Auth (Better Auth) ───────────────────────────────────────────────────────
BETTER_AUTH_SECRET=          # openssl rand -base64 32
BETTER_AUTH_URL=http://localhost:3000
# GitHub OAuth (sign in with GitHub + read repos/PRs for the public profile)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ── Email (Resend) ───────────────────────────────────────────────────────────
RESEND_API_KEY=
EMAIL_FROM=Orchid <noreply@orchidkeep.com>

# ── GitHub (PR review webhook + orchestrator pushes) ─────────────────────────
# Fine-grained PAT. Permissions: Contents: write, Pull requests: write.
GITHUB_TOKEN=ghp_...

# ── Web URLs ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:3000/api

# ── CLI (cli/) ───────────────────────────────────────────────────────────────
ORCHID_API_URL=http://localhost:3000/api
ORCHID_WEB_URL=http://localhost:3000
ORCHID_TOKEN=                # Personal access token minted in the web app
