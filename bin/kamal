#!/bin/bash
# Run Kamal via Docker (no Ruby install needed)
exec docker run --rm \
  -v "$PWD:/workdir" \
  -v "$HOME/.ssh:/root/.ssh:ro" \
  -v /var/run/docker.sock:/var/run/docker.sock \
  -v "$HOME/.docker:/root/.docker:ro" \
  --env-file <(env | grep -E '^(KAMAL_|OP_|GH_)') \
  -w /workdir \
  -it \
  ghcr.io/basecamp/kamal:latest "$@"
