# Block direct pushes to `main`. The orchestrator works on `orchestrator` + task branches;
# `main` is human-promotion only. Override (humans) with: git push --no-verify
while read -r local_ref local_sha remote_ref remote_sha; do
  case "$remote_ref" in
    refs/heads/main)
      echo "✗ pre-push: pushing to 'main' is blocked (orchestrator policy)."
      echo "  Use the 'orchestrator' branch; promote to main manually with --no-verify."
      exit 1
      ;;
  esac
done
exit 0
